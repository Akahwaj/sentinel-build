            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>SENTINEL Build Repository</summary>
            <description>One-Command Installation with 18 Premium Add-ons</description>
            <platform>all</platform>
            <license>GPL-3.0</license>
        </extension>
    </addon>

